NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Supabase Dashboard → Settings → API → anon public key (NOT the service_role key)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Supabase Dashboard → Settings → API → service_role secret key (server-side only, never NEXT_PUBLIC_)
SUPABASE_SERVICE_KEY=
NEXT_PUBLIC_SITE_URL=https://dumptruckboss.com

# Stripe API keys — dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Stripe Price IDs
STRIPE_OWNER_PRICE_ID=price_1TSsxw3t5rEtDPUVx5SXSFXQ
STRIPE_FLEET_PRICE_ID=price_1TSszJ3t5rEtDPUV0q3TdK7w
STRIPE_GROWTH_PRICE_ID=price_xxx  # $350/mo Growth plan — create in Stripe Dashboard
STRIPE_ENTERPRISE_PRICE_ID=price_1TStHW3t5rEtDPUVtHBi7LbU  # legacy alias for growth
# Stripe Webhook Secret — dashboard.stripe.com → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Anthropic — platform.anthropic.com → API Keys (required for OCR and AI chat)
ANTHROPIC_API_KEY=sk-ant-...

# Resend — resend.com → API Keys (required for dispatch email notifications)
RESEND_API_KEY=re_...

# Dispatch HMAC secret — generate with: openssl rand -hex 32
# Must be set in production; tokens signed with this secret cannot be forged
DISPATCH_HMAC_SECRET=

# Upstash Redis — console.upstash.com → your database → REST API
# Optional: without these, rate limiting falls back to in-memory (fine for single-instance dev)
# Required for production on Vercel (multiple serverless instances share the same store)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# Cron job secret — generate with: openssl rand -hex 32
# Vercel automatically sends this as Authorization: Bearer <CRON_SECRET> on cron requests
# Set this in Vercel Dashboard → Settings → Environment Variables
CRON_SECRET=
